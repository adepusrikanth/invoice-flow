# Copy this file to .env.local and fill in values.
# NEVER commit .env.local or any file containing real keys.

# OpenAI: set one of these (no quotes needed). Admin key can also be set at /admin.
OPENAI_API_KEY=
# Alternative name (also supported):
OPEN_AI_API_KEY=

# Admin: only this email can access /admin to set OpenAI key (no link in app; type /admin in URL).
ADMIN_EMAIL=

# Optional: override app URL (default http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: JWT secret for session signing (generate a random string)
JWT_SECRET=your-random-secret-at-least-32-chars

# Database (Prisma)
DATABASE_URL=file:./dev.db
